<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.EditBatteryActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:gravity="center"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editNbCells"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ems="10"
                android:hint="NbCells"
                android:inputType="number" />

            <EditText
                android:id="@+id/editCapacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ems="10"
                android:hint="Capacity"
                android:inputType="number" />

        </LinearLayout>

        <RadioGroup
            android:id="@+id/rgEtatCharge"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5">

            <RadioButton
                android:id="@+id/rbLow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Low" />

            <RadioButton
                android:id="@+id/rbStorage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Storage" />

            <RadioButton
                android:id="@+id/rbFull"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full" />
        </RadioGroup>

        <Button
            android:id="@+id/btnSaveChanges"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:text="Sauvegarder les modifications" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
